{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "R-Debugger",
            "name": "Launch R-Workspace",
            "request": "launch",
            "debugMode": "workspace",
            "workingDirectory": "${workspaceFolder}",
            "rPath": "C:/Users/huber/anaconda3/envs/python_r_env/Scripts/R.exe"
        },
        {
            "type": "R-Debugger",
            "name": "Debug R-File",
            "request": "launch",
            "debugMode": "file",
            "workingDirectory": "${workspaceFolder}",
            "file": "${file}",
            "rPath": "C:/Users/huber/anaconda3/envs/python_r_env/Scripts/R.exe"
        },
        {
            "type": "R-Debugger",
            "name": "Debug R-Function",
            "request": "launch",
            "debugMode": "function",
            "workingDirectory": "${workspaceFolder}",
            "file": "${file}",
            "mainFunction": "main",
            "allowGlobalDebugging": false,
            "rPath": "C:/Users/huber/anaconda3/envs/python_r_env/Scripts/R.exe"
        },
        {
            "type": "R-Debugger",
            "name": "Debug R-Package",
            "request": "launch",
            "debugMode": "workspace",
            "workingDirectory": "${workspaceFolder}",
            "includePackageScopes": true,
            "loadPackages": [
                "."
            ],
            "rPath": "C:/Users/huber/anaconda3/envs/python_r_env/Scripts/R.exe"
        },
        {
            "type": "R-Debugger",
            "request": "attach",
            "name": "Attach to R process",
            "splitOverwrittenOutput": true,
            "rPath": "C:/Users/huber/anaconda3/envs/python_r_env/Scripts/R.exe"
        }
    ]
}
